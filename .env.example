# Django
DJANGO_SECRET_KEY=change-this-to-a-random-50-char-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Supabase Postgres connection string
# Found in Supabase dashboard -> Project Settings -> Database -> Connection string (URI)
# Example: postgresql://postgres:[email protected]:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Telegram Bot
# Get this from @BotFather on Telegram after creating a bot with /newbot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_BOT_USERNAME=your_bot_username_without_at_sign

# Used to build the deep link t.me/<bot>?start=<token> and the webhook URL
# Must be your real public HTTPS domain in production (webhooks require HTTPS)
SITE_URL=https://yourdomain.com

# A secret path segment so randoms can't guess your webhook URL
TELEGRAM_WEBHOOK_SECRET=choose-a-random-string-here
